# Server
PORT=5000
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Database
MONGO_DB_CONNECTION_STRING=

# Auth tokens
ASSET_TOKEN_SECRET=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=

# Cloudinary (file uploads)
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# Password reset email (optional — logs reset link to console when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@moji.local
